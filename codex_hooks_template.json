{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON__ __HOOK__ idle",
            "timeout": 12
          }
        ],
        "matcher": "startup|resume"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON__ __HOOK__ working",
            "timeout": 12
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON__ __HOOK__ working",
            "timeout": 12
          }
        ],
        "matcher": ".*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON__ __HOOK__ working",
            "timeout": 12
          }
        ],
        "matcher": ".*"
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON__ __HOOK__ blocked",
            "timeout": 12
          }
        ],
        "matcher": ".*"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON__ __HOOK__ attention",
            "timeout": 12
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON__ __HOOK__ idle",
            "timeout": 12
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON__ __HOOK__ idle",
            "timeout": 12
          }
        ]
      }
    ]
  }
}
